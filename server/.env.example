# Copy this file to `.env` and fill in the values for your environment.

# API token used to authenticate requests to the server.  The client must
# include this token in the `Authorization: Bearer <API_TOKEN>` header.
API_TOKEN=change-me

# MQTT broker connection.  For a local broker via docker-compose, the URL
# below will work.  The client must be configured with the same broker
# address, username and password.
MQTT_URL=mqtt://mqtt-broker:1883

# Optional username/password.  If your broker enforces authentication,
# uncomment and set these values.  Leave them blank for anonymous access.
#MQTT_USER=myuser
#MQTT_PASS=secret

# MQTT topic on which print jobs will be published.  The ESP client
# subscribes to this topic.
MQTT_TOPIC=receipt/print

# Printer configuration.  `cpl` (characters per line) controls the width of
# the printed receipt.  `command` sets the ESC/POS command set.  See
# receiptline documentation for details.
PRINTER_CPL=42
PRINTER_COMMAND=escpos
PRINTER_ENCODING=multilingual

# Raster renderer settings. TM-P60II with 2-1/4 in / 58 mm rolls uses a
# 420-dot printable width. The renderer turns markdown/checklists/tables into
# fixed-width 1-bit raster bands at this exact width.
PRINTER_DOTS=420
RASTER_MARKDOWN=true
RASTER_BAND_HEIGHT=192
RASTER_THRESHOLD=160
RASTER_FONT_FAMILY=DejaVu Sans Mono, monospace
RASTER_FONT_SIZE=22
RASTER_LINE_HEIGHT=28
RASTER_MARGIN_X=0

# Port on which the HTTP API listens.  The container exposes this port.
PORT=3000
