# Copy this file to `.env` and fill in the values for your environment.

# API token used to authenticate requests to the server.  The client must
# include this token in the `Authorization: Bearer <API_TOKEN>` header,
# `X-API-Token` header, or `?token=` query parameter for MCP SSE clients.
API_TOKEN=change-me

# HTTP bind address. Use 0.0.0.0 in Docker, or 127.0.0.1 for local-only use.
HOST=0.0.0.0

# MQTT broker connection.  Docker Compose defaults to TLS on the internal
# broker listener.  The client must be configured with the same broker
# address, username and password.
MQTT_URL=mqtts://mqtt-broker:8883
MQTT_CA_CERT=/etc/printeasy/mqtt-ca.crt

# MQTT username/password.  Treat MQTT_PASS as an access token and use a long
# random value.
MQTT_USER=printeasy
MQTT_PASS=change-me

# MQTT topic on which print jobs will be published.  The ESP client
# subscribes to this topic.
MQTT_TOPIC=receipt/print

# Allow MCP requests to override the publish topic with a `topic` argument.
# Keep false unless you trust the MCP client and need per-printer topics.
ALLOW_TOPIC_OVERRIDE=false

# In-memory scheduled print queue. Scheduled jobs are kept while this server
# process is running. If MQTT is disconnected when a job is due, the queue
# retries until the broker reconnects.
PRINT_QUEUE_MAX_JOBS=100
PRINT_QUEUE_RETRY_MS=5000
PRINT_QUEUE_HISTORY_LIMIT=50

# Printer configuration.  `cpl` (characters per line) controls the width of
# the printed receipt.  `command` sets the ESC/POS command set.  See
# receiptline documentation for details.
PRINTER_CPL=42
PRINTER_COMMAND=escpos
PRINTER_ENCODING=multilingual

# Raster renderer settings. TM-P60II with 2-1/4 in / 58 mm rolls uses a
# 420-dot printable width. The renderer turns markdown/checklists/tables into
# fixed-width 1-bit raster bands at this exact width.
PRINTER_DOTS=420
RASTER_MARKDOWN=true
RASTER_BAND_HEIGHT=192
RASTER_THRESHOLD=160
RASTER_FONT_FAMILY=DejaVu Sans Mono, monospace
RASTER_FONT_SIZE=22
RASTER_LINE_HEIGHT=28
RASTER_MARGIN_X=0

# Port on which the HTTP API listens.  The container exposes this port.
PORT=3000
