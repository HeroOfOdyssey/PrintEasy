# MQTT broker connection.
MQTT_URL=mqtt://localhost:1883
MQTT_TOPIC=receipt/print
#MQTT_USER=
#MQTT_PASS=

# Choose one: serial, usb, bluetooth, file
TRANSPORT=serial

# Serial examples:
# DEVICE=/dev/ttyUSB0
# DEVICE=/dev/ttyAMA0
# Raw USB printer example:
# DEVICE=/dev/usb/lp0
# Bluetooth RFCOMM example after binding:
# DEVICE=/dev/rfcomm0
# Dry-run file output example:
# DEVICE=/tmp/printeasy-output.bin
DEVICE=/dev/ttyUSB0

# Serial transport settings.
SERIAL_BAUD=9600
SERIAL_TIMEOUT=5

# Write behavior.
WRITE_CHUNK_SIZE=4096
RECONNECT_INTERVAL=5
DRY_RUN=false
